# ─── CloudVault — Required Environment Variables ──────────────────────────────
# Copy this file to .env and fill in real values. Never commit .env to git.

# ── Database ──────────────────────────────────────────────────────────────────
DB_NAME=cloudvault
DB_URL=jdbc:mysql://localhost:3306/cloudvault?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DB_USERNAME=cloudvault
DB_PASSWORD=change_me
MYSQL_ROOT_PASSWORD=change_me_root

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a secure 256-bit secret: openssl rand -base64 32
JWT_SECRET=replace_with_a_secure_256_bit_random_string
JWT_EXPIRY_MS=900000
JWT_REFRESH_EXPIRY_MS=604800000

# ── AWS S3 ────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=ap-south-1
AWS_BUCKET_NAME=cloudvault-dev-files
